# plane_pages_mcp configuration. Copy to .env and fill in. Never commit .env.
#
# Two independent subsystems — configure either or both:
#   pages  (DB + live converter): DATABASE_URL [+ SERVICE_USER_ID to write]
#   items  (public REST API):     PLANE_BASE_URL + PLANE_API_KEY
# The server starts if at least one is configured; a missing PAT never breaks
# pages and a missing DB never breaks work items.

# --- pages subsystem ---
# Dedicated read/write-limited role (see README "Database role").
# Inside the compose network use host `plane-db`; from the host use localhost.
DATABASE_URL=postgresql://plane_pages:CHANGEME@localhost:5432/plane

# UUID of the user that tool-created pages are owned by. A SINGLE user is used
# for every workspace (attribution to the operator; simpler than per-workspace
# bot users). Required whenever DATABASE_URL is set.
SERVICE_USER_ID=00000000-0000-0000-0000-000000000000

# Internal live-service converter. Inside compose the default host works;
# from the host during dev use http://localhost:3300/live/convert-document/.
LIVE_CONVERT_URL=http://live:3000/live/convert-document/

# Used to build the UI URL returned by create_page.
PLANE_WEB_URL=http://localhost

# --- work-items subsystem (REST) ---
# Instance site root; the client appends /api/v1. Unrelated to LIVE_CONVERT_URL.
PLANE_BASE_URL=http://localhost
# Personal access token, sent as header `x-api-key`.
PLANE_API_KEY=plane_api_xxxxxxxxxxxxxxxxxxxxxxxx

# --- shared ---
# DEFAULT workspace slug (not a fixture). Every tool takes an optional
# `workspace` arg; when omitted, reads/lists fall back to this. create_page and
# create_work_item ignore it and REQUIRE an explicit workspace. May be unset,
# in which case callers must always pass `workspace`.
WORKSPACE_SLUG=test

# Required in http mode: every request must send `Authorization: Bearer <token>`.
MCP_AUTH_TOKEN=change-me-to-a-long-random-string

# http (streamable, 0.0.0.0:8300/mcp) or stdio (for local dev clients).
MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=8300
MCP_PATH=/mcp

# Never logs page content above DEBUG.
LOG_LEVEL=INFO
