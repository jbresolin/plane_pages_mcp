# plane_pages_mcp configuration. Copy to .env and fill in. Never commit .env.

# --- required ---
# Dedicated read/write-limited role (see README "Database role").
# When running INSIDE the compose network use host `plane-db`; from the host
# during dev use `localhost:5432`.
DATABASE_URL=postgresql://plane_pages:CHANGEME@localhost:5432/plane

# Workspace whose pages this server manages (resolved to an id at startup).
WORKSPACE_SLUG=test

# UUID of the user that tool-created pages are owned by (a bot/service account).
SERVICE_USER_ID=00000000-0000-0000-0000-000000000000

# Required in http mode: every request must send `Authorization: Bearer <token>`.
MCP_AUTH_TOKEN=change-me-to-a-long-random-string

# --- optional (defaults shown) ---
# Internal live-service converter. Inside compose the default host works;
# from the host during dev use http://localhost:3300/live/convert-document/.
LIVE_CONVERT_URL=http://live:3000/live/convert-document/

# Used to build the UI URL returned by create_page.
PLANE_WEB_URL=http://localhost

# http (streamable, 0.0.0.0:8300/mcp) or stdio (for local dev clients).
MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=8300
MCP_PATH=/mcp

# Never logs page content above DEBUG.
LOG_LEVEL=INFO
