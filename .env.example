# plane_pages_mcp configuration. Copy to .env and fill in. Never commit .env.
#
# Two independent subsystems — configure either or both:
#   pages  (DB + live converter): DATABASE_URL [+ SERVICE_USER_ID to write]
#   items  (public REST API):     PLANE_BASE_URL + PLANE_API_KEY
# The server starts if at least one is configured; a missing PAT never breaks
# pages and a missing DB never breaks work items.

# --- pages subsystem ---
# Dedicated read/write-limited role (see README "Database role").
# Inside the compose network use host `plane-db`; from the host use localhost.
DATABASE_URL=postgresql://plane_pages:CHANGEME@localhost:5432/plane

# UUID of the user that tool-created pages are owned by. A SINGLE user is used
# for every workspace (attribution to the operator; simpler than per-workspace
# bot users). Required whenever DATABASE_URL is set.
SERVICE_USER_ID=00000000-0000-0000-0000-000000000000

# Internal live-service converter. Inside compose the default host works;
# from the host during dev use http://localhost:3300/live/convert-document/.
LIVE_CONVERT_URL=http://live:3000/live/convert-document/

# Used to build the UI URL returned by create_page.
PLANE_WEB_URL=http://localhost

# --- work-items subsystem (REST) ---
# Instance site root; the client appends /api/v1. Unrelated to LIVE_CONVERT_URL.
PLANE_BASE_URL=http://localhost
# Personal access token, sent as header `x-api-key`.
PLANE_API_KEY=plane_api_xxxxxxxxxxxxxxxxxxxxxxxx

# --- shared ---
# DEFAULT workspace slug (not a fixture). Every tool takes an optional
# `workspace` arg; when omitted, reads/lists fall back to this. create_page and
# create_work_item ignore it and REQUIRE an explicit workspace. May be unset,
# in which case callers must always pass `workspace`.
WORKSPACE_SLUG=test

# --- auth (http transport only) ---
# http mode is protected by GitHub OAuth (FastMCP GitHubProvider) + an allowlist
# of GitHub logins. All the vars below are REQUIRED in http mode — the server
# fails fast at startup if any is missing. stdio mode ignores all of them.

# Per-environment GitHub OAuth app (register two: prod + dev). Callback URL must
# be exactly <PUBLIC_BASE_URL>/auth/callback. Minimal scope (read:user).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public origin this server is reached at (no trailing slash, no /mcp).
# prod: https://planemcp.<domain>   dev: http://localhost:8300
PUBLIC_BASE_URL=http://localhost:8300

# Comma-separated GitHub logins allowed to use the tools. NO default — an empty
# list is rejected. Case-insensitive. THIS is the authorization gate.
ALLOWED_GITHUB_LOGINS=

# Long random secret signing the FastMCP JWTs. MUST be stable across restarts
# (a new key invalidates all issued tokens). >= 12 chars.
JWT_SIGNING_KEY=

# Redis (the stack's plane-redis/valkey) for OAuth state, encrypted at rest.
# Use logical DB 1 to isolate OAuth keys from Plane's own Redis use (DB 0).
# In compose: redis://plane-redis:6379/1
REDIS_URL=redis://plane-redis:6379/1
# Long secret; derives the Fernet key that encrypts stored OAuth state at rest.
# Keep INDEPENDENT of JWT_SIGNING_KEY — they rotate for different reasons (leaked
# Redis data vs. leaked JWT) and a shared secret couples both compromises.
STORAGE_ENCRYPTION_KEY=

# Optional: FastMCP access-token lifetime (default 7 days).
TOKEN_EXPIRY_SECONDS=604800

# http (streamable, 0.0.0.0:8300/mcp; GitHub OAuth) or stdio (on-box, auth-free).
MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=8300
MCP_PATH=/mcp

# Never logs page content above DEBUG. Set DEBUG to see the OAuth token claim
# keys once (to confirm the GitHub login claim during first setup).
LOG_LEVEL=INFO
